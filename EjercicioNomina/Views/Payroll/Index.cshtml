@model EjercicioNomina.Domain.Employee

@{
    ViewData["Title"] = "Cálculo de Nómina";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">
            <div class="card shadow p-4">

                <h2 class="text-center mb-4">Cálculo de Nómina</h2>

                <form asp-action="Calculate" method="post">

                    <div class="mb-3">
                        <label class="form-label">Nombre</label>
                        <input asp-for="Name" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Rol</label>
                        <select asp-for="Role" class="form-select">
                            <option value="0">Chofer</option>
                            <option value="1">Cargador</option>
                            <option value="2">Auxiliar</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Tipo</label>
                        <select asp-for="Type" class="form-select">
                            <option value="0">Interno</option>
                            <option value="1">Subcontratado</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Horas trabajadas</label>
                        <input asp-for="HoursWorked" type="number" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Entregas realizadas</label>
                        <input asp-for="Deliveries" type="number" class="form-control" />
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        Calcular
                    </button>

                </form>

            </div>
        </div>
    </div>
</div>