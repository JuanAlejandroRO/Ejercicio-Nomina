@{
    ViewData["Title"] = "Cálculo de Nómina";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">
            <div class="card shadow p-4">
                <h2 class="text-center mb-4">Cálculo de Nómina</h2>

                <form method="post">

                    <div class="mb-3">
                        <label class="form-label">Nombre</label>
                        <input type="text" name="Nombre" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Rol</label>
                        <select name="Rol" class="form-select">
                            <option>Chofer</option>
                            <option>Administrador</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Tipo</label>
                        <select name="Tipo" class="form-select">
                            <option>Interno</option>
                            <option>Externo</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Horas trabajadas</label>
                        <input type="number" name="Horas" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Entregas realizadas</label>
                        <input type="number" name="Entregas" class="form-control" />
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        Calcular
                    </button>

                </form>

            </div>
        </div>
    </div>
</div>