@model Nomina.Domain.Employee

<div class="container mt-4">

    <div class="card">
        <div class="card-header bg-secondary text-white">
            <h4>Captura de movimientos</h4>
        </div>

        <div class="card-body">

            <!-- BOTONES SUPERIORES (NAVEGACIÓN) -->
            <div class="mb-4 text-center">

                <a asp-action="Index" class="btn btn-outline-primary me-2">
                    Nuevo
                </a>

                <a asp-action="Buscar" class="btn btn-outline-secondary me-2">
                    Buscar
                </a>

                <a asp-action="Editar" class="btn btn-outline-warning me-2">
                    Modificar
                </a>

                <a asp-action="Eliminar" class="btn btn-outline-danger">
                    Eliminar
                </a>

            </div>

            <!-- FORMULARIO NUEVO -->
            <form asp-action="Guardar" method="post">

                <input type="hidden" asp-for="Id" />

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label>Número de empleado:</label>
                        <input asp-for="Id" class="form-control" />
                    </div>

                    <div class="col-md-6">
                        <label>Nombre:</label>
                        <input asp-for="Name" class="form-control" />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label>Rol:</label>
                        <select asp-for="Role" class="form-control">
                            <option value="0">Chofer</option>
                            <option value="1">Cargador</option>
                            <option value="2">Auxiliar</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label>Fecha:</label>
                        <input asp-for="Date"
                               type="date"
                               class="form-control"
                               value="@(Model.Date == DateTime.MinValue
                                                                      ? DateTime.Today.ToString("yyyy-MM-dd")
                                                                      : Model.Date.ToString("yyyy-MM-dd"))" />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label>Horas trabajadas:</label>
                        <input asp-for="HoursWorked" type="number" class="form-control" />
                    </div>

                    <div class="col-md-6">
                        <label>Cantidad de entregas:</label>
                        <input asp-for="Deliveries" type="number" class="form-control" />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label>Tipo:</label><br />
                        <input type="radio" asp-for="Type" value="0" /> Interno
                        <input type="radio" asp-for="Type" value="1" /> Externo
                    </div>

                    <div class="col-md-6">
                        <input type="checkbox" asp-for="CoveredShift" />
                        <label>Cubrió turno</label>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label>Rol cubierto:</label>
                        <select asp-for="CoveredRole" class="form-control">
                            <option value="">-- Ninguno --</option>
                            <option value="0">Chofer</option>
                            <option value="1">Cargador</option>
                            <option value="2">Auxiliar</option>
                        </select>
                    </div>
                </div>

                <div class="text-end mt-4">
                    <button type="submit" class="btn btn-success">
                        Guardar
                    </button>

                    <button type="reset" class="btn btn-secondary">
                        Cancelar
                    </button>
                </div>

            </form>

        </div>
    </div>

</div>