@model Nomina.Domain.Employee

<div class="container mt-4">

    <div class="card">
        <div class="card-header bg-secondary text-white">
            <h4>Empleados</h4>
        </div>

        <div class="card-body">

            <!-- Botones superiores -->
            <div class="mb-4 text-center">
                <button class="btn btn-outline-primary me-2">Nuevo</button>
                <button class="btn btn-outline-secondary me-2">Buscar</button>
                <button class="btn btn-outline-warning me-2">Modificar</button>
                <button class="btn btn-outline-danger">Eliminar</button>
            </div>

            <form asp-action="Calculate" method="post">

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label>Número:</label>
                        <input asp-for="Id" class="form-control" />
                    </div>

                    <div class="col-md-6">
                        <label>Nombre:</label>
                        <input asp-for="Name" class="form-control" />
                    </div>
                </div>

                <div class="row">

                    <!-- Rol -->
                    <div class="col-md-6">
                        <div class="border p-3">
                            <label><strong>Rol:</strong></label><br />

                            <input type="radio" asp-for="Role" value="0" /> Chofer <br />
                            <input type="radio" asp-for="Role" value="1" /> Cargador <br />
                            <input type="radio" asp-for="Role" value="2" /> Auxiliar
                        </div>
                    </div>

                    <!-- Tipo -->
                    <div class="col-md-6">
                        <div class="border p-3">
                            <label><strong>Tipo:</strong></label><br />

                            <input type="radio" asp-for="Type" value="0" /> Interno <br />
                            <input type="radio" asp-for="Type" value="1" /> Subcontratado
                        </div>
                    </div>

                </div>

                <div class="text-end mt-4">
                    <button type="submit" class="btn btn-success">Guardar</button>
                    <button type="reset" class="btn btn-secondary">Cancelar</button>
                </div>

            </form>

        </div>
    </div>

</div>